{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": ["node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
  },
  "include": ["./**/*.ts"]
}